{
  "recipe": "p-reels-split",
  "spec_version": 1,
  "_note": "Strict, recipe-owned spec read by c-eval-runner. A brand may layer brand-overrides/<slug>/acceptance.json to TIGHTEN thresholds (same id wins; new ids appended). See cfw-skills-pack/docs/skills-audit.md §4.",
  "checks": [
    { "id": "qa_gate", "kind": "mechanical", "type": "qa_gate", "format": "reel" },
    { "id": "duration_window", "kind": "mechanical", "type": "duration_window", "min_s": 20, "max_s": 62 },
    { "id": "canvas_1080x1920", "kind": "geometry", "type": "dims", "w": 1080, "h": 1920 },
    { "id": "top_zone_not_black", "kind": "geometry", "type": "luma_floor",
      "crop": "1080:960:0:0", "floor": 16, "samples": [0.05, 0.20, 0.40, 0.60, 0.80, 0.95] },

    { "id": "top_has_content", "kind": "perceptual", "type": "perceptual",
      "desc": "(a) Top half shows motion graphics or b-roll — never an empty/black zone." },
    { "id": "face_complete", "kind": "perceptual", "type": "perceptual",
      "desc": "(b) Bottom half shows the complete face; forehead and chin both visible." },
    { "id": "hard_split_line", "kind": "perceptual", "type": "perceptual",
      "desc": "(c) Clean split at y=960 — top and bottom zones do not overlap or bleed." },
    { "id": "face_fills_bottom", "kind": "perceptual", "type": "perceptual",
      "desc": "(d) Face fills the full bottom 960px; it is not a small inset." },
    { "id": "no_pillarbox", "kind": "perceptual", "type": "perceptual",
      "desc": "(e) No pillarbox bars in either zone; blurred-fill covers any aspect gaps." },
    { "id": "captions_top_only", "kind": "perceptual", "type": "perceptual",
      "desc": "(f) Captions appear in the top zone only — none over the bottom-half face." },
    { "id": "cover_is_moneyshot", "kind": "perceptual", "type": "perceptual",
      "desc": "(g) Frame 0 (cover) is the money-shot — not black, not a mid-motion frame." }
  ],
  "steps": {
    "voicebed": {
      "artifact": "voice-bed.aac",
      "checks": [
        { "id": "bed_loudness", "kind": "mechanical", "type": "loudness", "target": -14, "tol": 1.5 },
        { "id": "bed_has_speech", "kind": "mechanical", "type": "mean_volume", "min_db": -32, "max_db": -8 }
      ]
    },
    "toptrack": {
      "artifact": "top-all.mp4",
      "checks": [
        { "id": "top_track_dims", "kind": "geometry", "type": "dims", "w": 1080, "h": 960 },
        { "id": "top_track_not_black", "kind": "geometry", "type": "luma_floor",
          "crop": "1080:960:0:0", "floor": 16, "samples": [0.1, 0.3, 0.5, 0.7, 0.9] }
      ]
    },
    "composite": {
      "artifact": "composite.mp4",
      "checks": [
        { "id": "composite_dims", "kind": "geometry", "type": "dims", "w": 1080, "h": 1920 }
      ]
    }
  }
}
